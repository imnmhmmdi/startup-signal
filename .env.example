# Database — use Shared Pooler for Vercel (IPv4-compatible)
# Supabase Dashboard → Connect → Connection pooling → Transaction pooler
# postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Do NOT use db.[ref].supabase.co on Vercel — that hostname is IPv6-only.
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (for LLM company briefs)
ANTHROPIC_API_KEY=sk-ant-your-key

# Cron job authentication (set in Vercel env)
CRON_SECRET=your-random-secret

# Auto-seed when companies table is empty (default: true)
SEED_ON_DEPLOY=true
